@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,400;1,600;1,700&family=Inter:wght@300;400;500;600;700;800&display=swap');
:root{
--navy:#1a2332;--navy-deep:#0f1923;--gold:#b8860b;--gold-light:#d4a843;--gold-pale:#f5e6c8;
--cream:#faf6ef;--cream-dark:#f0e8d8;--white:#ffffff;--text:#2c3e50;--text-light:#6b7c93;
--text-muted:#94a3b8;--border:rgba(184,134,11,0.15);--border-light:#e8e0d0;
--glass:rgba(255,255,255,0.7);--glass-border:rgba(255,255,255,0.3);
--shadow:0 4px 30px rgba(0,0,0,0.08);--shadow-lg:0 20px 60px rgba(0,0,0,0.12);
--shadow-gold:0 8px 30px rgba(184,134,11,0.2);--radius:16px;--radius-lg:24px;--radius-full:9999px;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--cream);color:var(--text);line-height:1.7;overflow-x:hidden;-webkit-font-smoothing:antialiased}
h1,h2,h3,h4{font-family:'Playfair Display',serif;color:var(--navy);line-height:1.2;font-weight:700}
a{text-decoration:none;color:inherit;transition:all .3s ease}
img{max-width:100%;display:block}
ul{list-style:none}
.container{width:90%;max-width:1200px;margin:0 auto;padding:0 20px}

/* HEADER - Glassmorphism */
header{position:fixed;top:0;left:0;right:0;z-index:1000;height:72px;display:flex;align-items:center;justify-content:space-between;padding:0 5%;background:var(--glass);backdrop-filter:blur(20px) saturate(180%);-webkit-backdrop-filter:blur(20px) saturate(180%);border-bottom:1px solid var(--glass-border);transition:all .4s ease}
header.scrolled{height:60px;background:rgba(255,255,255,0.92);box-shadow:var(--shadow)}
.logo-wrap{display:flex;align-items:center;gap:12px}
.logo-img{height:48px;width:auto;object-fit:contain;transition:all .3s}
header.scrolled .logo-img{height:40px}
.logo-name{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;transition:all .3s}
.logo-word1{color:var(--navy)}.logo-word2{color:var(--gold);font-style:italic}
header.scrolled .logo-name{font-size:1.2rem}
nav ul{display:flex;align-items:center;gap:4px}
nav ul li a{padding:8px 18px;border-radius:6px;font-size:.9rem;font-weight:500;color:var(--text-light);transition:all .2s}
nav ul li a:hover{color:var(--navy);background:rgba(184,134,11,0.06)}
nav ul li a.active{color:var(--gold);font-weight:600}
.nav-cta{background:var(--gold)!important;color:var(--white)!important;padding:10px 26px!important;border-radius:var(--radius-full)!important;font-weight:600!important;box-shadow:var(--shadow-gold);transition:all .3s!important}
.nav-cta:hover{background:var(--gold-light)!important;transform:translateY(-1px);box-shadow:0 12px 35px rgba(184,134,11,0.3)!important}
.mobile-menu-btn{display:none;color:var(--navy);font-size:1.4rem;cursor:pointer;padding:8px}

/* HERO */
.hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;align-items:center;gap:60px;padding:120px 5% 80px;position:relative;overflow:hidden;background:linear-gradient(135deg,var(--cream) 0%,var(--cream-dark) 40%,rgba(184,134,11,0.05) 100%)}
.hero::before{content:'';position:absolute;top:0;right:0;width:55%;height:100%;background:url('hero-bg.png') center/cover no-repeat;opacity:.35;mask-image:linear-gradient(to left,rgba(0,0,0,0.6) 0%,transparent 80%);-webkit-mask-image:linear-gradient(to left,rgba(0,0,0,0.6) 0%,transparent 80%)}
.hero-content{position:relative;z-index:2;max-width:600px}
.hero-eyebrow{display:inline-flex;align-items:center;gap:10px;font-size:.72rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:24px}
.hero-eyebrow::before{content:'';width:32px;height:2px;background:var(--gold)}
.hero h1{font-size:clamp(2.5rem,5.5vw,3.8rem);font-weight:800;margin-bottom:24px;letter-spacing:-.02em}
.hero h1 em{font-style:italic;color:var(--gold)}
.hero-sub{font-size:1.1rem;color:var(--text-light);max-width:520px;line-height:1.8;margin-bottom:36px}
.hero-actions{display:flex;gap:16px;margin-bottom:48px;flex-wrap:wrap}
.hero-stats{display:flex;gap:40px;flex-wrap:wrap}
.hero-stat{text-align:left;position:relative;padding-left:20px}
.hero-stat::before{content:'';position:absolute;left:0;top:4px;bottom:4px;width:2px;background:var(--gold)}
.hero-stat .number{font-family:'Playfair Display',serif;font-size:2rem;font-weight:800;color:var(--navy);line-height:1}
.hero-stat .label{font-size:.82rem;color:var(--text-muted);margin-top:4px}

/* Hero 3D Carousel */
.hero-carousel{position:relative;z-index:2;padding:20px 0}
.carousel-glow{position:absolute;top:50%;left:50%;width:350px;height:350px;border-radius:50%;background:radial-gradient(circle,rgba(184,134,11,0.18) 0%,transparent 70%);transform:translate(-50%,-50%);filter:blur(50px);animation:pulseGlow 4s ease-in-out infinite;pointer-events:none}
@keyframes pulseGlow{0%,100%{opacity:.5;transform:translate(-50%,-50%) scale(1)}50%{opacity:1;transform:translate(-50%,-50%) scale(1.25)}}
.carousel-viewport{overflow:visible;position:relative;height:420px;display:flex;align-items:center;justify-content:center}
.carousel-track{display:flex;align-items:center;justify-content:center;position:relative;width:100%;height:100%}
.carousel-slide{position:absolute;width:340px;transition:all .6s cubic-bezier(.4,0,.2,1);will-change:transform,opacity,filter}
.carousel-slide[data-pos="center"]{transform:translateX(0) scale(1);opacity:1;z-index:10;filter:none}
.carousel-slide[data-pos="left"]{transform:translateX(-65%) scale(0.78);opacity:.5;z-index:5;filter:blur(4px)}
.carousel-slide[data-pos="right"]{transform:translateX(65%) scale(0.78);opacity:.5;z-index:5;filter:blur(4px)}
.carousel-slide[data-pos="far-left"]{transform:translateX(-120%) scale(0.6);opacity:0;z-index:1;filter:blur(8px);pointer-events:none}
.carousel-slide[data-pos="far-right"]{transform:translateX(120%) scale(0.6);opacity:0;z-index:1;filter:blur(8px);pointer-events:none}
.carousel-slide[data-pos="hidden"]{transform:translateX(0) scale(0.5);opacity:0;z-index:0;pointer-events:none}

/* Premium Glassmorphic Cards */
.c-card{background:rgba(255,255,255,0.12);backdrop-filter:blur(28px) saturate(200%);-webkit-backdrop-filter:blur(28px) saturate(200%);border:1px solid rgba(255,255,255,0.2);border-radius:20px;padding:32px 28px 28px;position:relative;overflow:hidden;box-shadow:0 20px 50px rgba(0,0,0,0.06),0 0 0 1px rgba(255,255,255,0.08) inset;transition:all .4s}
.carousel-slide[data-pos="center"] .c-card{background:rgba(255,255,255,0.65);border:1px solid rgba(255,255,255,0.5);box-shadow:0 24px 60px rgba(0,0,0,0.1),0 0 80px rgba(184,134,11,0.06),inset 0 1px 0 rgba(255,255,255,0.7)}
.c-card-shine{position:absolute;top:0;left:-75%;width:50%;height:100%;background:linear-gradient(105deg,transparent 40%,rgba(255,255,255,0.15) 45%,rgba(255,255,255,0.05) 50%,transparent 55%);transition:left .8s ease;pointer-events:none}
.carousel-slide[data-pos="center"] .c-card:hover .c-card-shine{left:125%}
.c-card-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.c-icon{width:56px;height:56px;border-radius:16px;background:linear-gradient(135deg,var(--gold),var(--gold-light));display:flex;align-items:center;justify-content:center;font-size:1.3rem;color:var(--white);box-shadow:0 6px 20px rgba(184,134,11,0.35);position:relative}
.c-icon::after{content:'';position:absolute;inset:0;border-radius:16px;background:linear-gradient(135deg,transparent 45%,rgba(255,255,255,0.25) 50%,transparent 55%);opacity:0;animation:iconGlint 4s ease-in-out infinite}
.carousel-slide[data-pos="center"] .c-icon::after{opacity:1}
@keyframes iconGlint{0%,100%{transform:translateX(-150%) rotate(35deg)}50%{transform:translateX(150%) rotate(35deg)}}
.c-badge-pill{background:rgba(184,134,11,0.1);color:var(--gold);padding:5px 14px;border-radius:var(--radius-full);font-size:.7rem;font-weight:700;letter-spacing:.5px;display:flex;align-items:center;gap:5px;border:1px solid rgba(184,134,11,0.15)}
.c-card h3{font-size:1.25rem;font-weight:800;color:var(--navy);margin-bottom:10px;line-height:1.3}
.c-card>p{font-size:.88rem;color:var(--text-light);line-height:1.7;margin-bottom:16px;min-height:48px}
.c-divider{height:1px;background:linear-gradient(90deg,transparent,rgba(184,134,11,0.2),transparent);margin-bottom:16px}
.c-stats-row{display:flex;gap:16px;margin-bottom:16px}
.c-stat{flex:1;background:rgba(184,134,11,0.04);border:1px solid rgba(184,134,11,0.1);border-radius:12px;padding:10px 14px;text-align:center}
.c-stat-val{display:block;font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:800;color:var(--gold);line-height:1.2}
.c-stat-lbl{font-size:.68rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px;font-weight:600}
.c-tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:18px}
.c-tags span{background:rgba(184,134,11,0.06);color:var(--gold);padding:4px 12px;border-radius:var(--radius-full);font-size:.72rem;font-weight:600;border:1px solid rgba(184,134,11,0.1)}
.c-card-btn{display:inline-flex;align-items:center;gap:6px;font-size:.82rem;font-weight:700;color:var(--gold);padding:8px 0;border-bottom:2px solid transparent;transition:all .3s}
.c-card-btn:hover{border-bottom-color:var(--gold);gap:10px}
.carousel-controls{display:flex;align-items:center;justify-content:center;gap:16px;margin-top:24px;position:relative;z-index:11}
.carousel-btn{width:44px;height:44px;border-radius:50%;border:1.5px solid var(--border-light);background:rgba(255,255,255,0.6);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);color:var(--navy);font-size:.85rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .3s}
.carousel-btn:hover{background:var(--gold);color:var(--white);border-color:var(--gold);transform:scale(1.08)}
.carousel-dots{display:flex;gap:10px}
.carousel-dots .c-dot{width:10px;height:10px;border-radius:50%;background:var(--border-light);cursor:pointer;transition:all .4s}
.carousel-dots .c-dot.active{background:var(--gold);width:32px;border-radius:var(--radius-full);box-shadow:0 0 12px rgba(184,134,11,0.4)}
.carousel-refund-badge{position:absolute;top:10px;right:-10px;background:linear-gradient(135deg,var(--gold),var(--gold-light));color:var(--white);width:80px;height:80px;border-radius:50%;display:flex;flex-direction:column;align-items:center;justify-content:center;font-weight:800;box-shadow:0 8px 24px rgba(184,134,11,0.35);font-size:.65rem;line-height:1.2;z-index:15;animation:floatBadge 3s ease-in-out infinite}
.carousel-refund-badge .big{font-size:1.3rem}
@keyframes floatBadge{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}

/* BUTTONS */
.btn-primary{display:inline-flex;align-items:center;gap:8px;background:var(--gold);color:var(--white);padding:14px 32px;border-radius:var(--radius-full);font-weight:600;font-size:.92rem;border:none;cursor:pointer;box-shadow:var(--shadow-gold);transition:all .3s}
.btn-primary:hover{background:var(--gold-light);transform:translateY(-2px);box-shadow:0 12px 35px rgba(184,134,11,0.35)}
.btn-outline{display:inline-flex;align-items:center;gap:8px;background:transparent;color:var(--navy);padding:14px 32px;border:2px solid var(--border-light);border-radius:var(--radius-full);font-weight:600;font-size:.92rem;cursor:pointer;transition:all .3s}
.btn-outline:hover{border-color:var(--gold);color:var(--gold);background:rgba(184,134,11,0.04);transform:translateY(-2px)}
.btn-large{padding:16px 40px;font-size:1rem}

/* SECTION HELPERS */
.section-ornament{display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:12px}
.section-ornament span{font-size:.72rem;font-weight:700;letter-spacing:3.5px;text-transform:uppercase;color:var(--gold)}
.section-ornament::before,.section-ornament::after{content:'';width:32px;height:2px;background:var(--gold);opacity:.4}
.section-title{font-size:clamp(1.8rem,4vw,2.6rem);text-align:center;margin-bottom:14px;font-weight:800}
.section-title em{color:var(--gold);font-style:italic}
.section-subtitle{text-align:center;color:var(--text-light);max-width:580px;margin:0 auto 56px;font-size:1.05rem;line-height:1.7}

/* STATS */
.stats-section{padding:70px 0;background:var(--white)}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
.stat-card{text-align:center;padding:32px 20px;border-radius:var(--radius-lg);background:var(--cream);border:1px solid var(--border-light);transition:all .4s}
.stat-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-lg);border-color:rgba(184,134,11,0.3)}
.stat-number{font-family:'Playfair Display',serif;font-size:2.8rem;font-weight:800;color:var(--navy);line-height:1;margin-bottom:6px}
.stat-number span{color:var(--gold)}
.stat-label{font-size:.88rem;color:var(--text-light);font-weight:500}

/* SERVICES */
.services-section{padding:100px 0;background:var(--cream-dark)}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.service-card{background:var(--white);border:1px solid var(--border-light);border-radius:var(--radius-lg);padding:40px 32px;transition:all .4s;position:relative;overflow:hidden}
.service-card:hover{transform:translateY(-8px);box-shadow:var(--shadow-lg);border-color:rgba(184,134,11,0.3)}
.service-icon{width:56px;height:56px;border-radius:var(--radius);background:rgba(184,134,11,0.08);display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:var(--gold);margin-bottom:22px}
.service-card h3{font-size:1.15rem;margin-bottom:12px}
.service-card p{color:var(--text-light);font-size:.9rem;line-height:1.7;margin-bottom:20px}
.card-link{font-size:.88rem;font-weight:600;color:var(--gold);display:inline-flex;align-items:center;gap:6px}
.card-link:hover{gap:10px}

/* VALUE SECTION */
.value-section{padding:100px 0;background:var(--white)}
.value-inner{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
.value-left .overline{font-size:.72rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--gold);margin-bottom:16px}
.value-left h2{font-size:2.2rem;font-weight:800;margin-bottom:20px}
.value-left p{color:var(--text-light);font-size:1.05rem;line-height:1.75;margin-bottom:32px}
.value-left .highlight{color:var(--gold);font-weight:700}
.value-right{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.v-item{background:var(--cream);border:1px solid var(--border-light);border-radius:var(--radius);padding:28px 22px;transition:all .3s}
.v-item:hover{transform:translateY(-4px);box-shadow:var(--shadow);border-color:rgba(184,134,11,0.3)}
.v-item i{font-size:1.5rem;color:var(--gold);margin-bottom:12px;display:block}
.v-item h4{font-size:.95rem;margin-bottom:6px}
.v-item p{font-size:.85rem;color:var(--text-light);line-height:1.6}

/* COMPARISON */
.comparison-section{padding:100px 0;background:var(--cream-dark)}
.cmp-grid{display:grid;grid-template-columns:1fr 1fr;gap:0;border-radius:var(--radius-lg);overflow:hidden;border:1px solid var(--border-light);box-shadow:var(--shadow-lg);background:var(--white)}
.cmp-col--us{background:rgba(184,134,11,0.04)}
.cmp-head{padding:28px 24px;text-align:center;min-height:90px;display:flex;flex-direction:column;align-items:center;justify-content:center}
.cmp-badge{display:inline-flex;align-items:center;gap:8px;padding:8px 18px;border-radius:var(--radius-full);font-size:.85rem;font-weight:700}
.cmp-badge--us{background:var(--gold);color:var(--white)}
.cmp-badge--others{background:var(--cream-dark);color:var(--text-light)}
.cmp-col-sub{font-size:.8rem;color:var(--text-muted);margin-top:6px}
.cmp-cell{display:flex;align-items:flex-start;gap:12px;padding:16px 24px;font-size:.88rem;border-top:1px solid var(--border-light)}
.cmp-col--us .cmp-cell i{color:#10b981;margin-top:3px;flex-shrink:0}
.cmp-col--others .cmp-cell i{color:#ef4444;margin-top:3px;flex-shrink:0}
.cmp-col--labels{background:var(--cream)}
.cmp-lbl{font-weight:600;justify-content:center}
.cmp-lbl i{color:var(--gold);margin-top:3px}

/* PROCESS */
.process-section{padding:100px 0;background:var(--white)}
.process-steps{display:grid;grid-template-columns:repeat(5,1fr);gap:28px}
.step{text-align:center;position:relative}
.step-circle{width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--gold-light));color:var(--white);font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:800;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;box-shadow:var(--shadow-gold);transition:all .3s}
.step:hover .step-circle{transform:scale(1.1)}
.step h3{font-size:1rem;margin-bottom:8px}
.step p{font-size:.85rem;color:var(--text-light);line-height:1.6}

/* TESTIMONIALS */
.testimonials-section{padding:100px 0;background:var(--cream-dark);overflow:hidden}
.testimonials-slider{overflow:hidden}
.testimonials-track{display:flex;transition:transform .5s cubic-bezier(.4,0,.2,1)}
.testimonial-card{min-width:calc(33.333% - 24px);padding:36px;background:var(--white);border:1px solid var(--border-light);border-radius:var(--radius-lg);margin:0 12px;flex-shrink:0}
.quote-mark{font-size:3rem;color:var(--gold);line-height:1;font-family:Georgia,serif}
.stars{color:var(--gold);margin:8px 0 16px;font-size:.85rem;letter-spacing:2px}
.testimonial-card>p{color:var(--text-light);font-size:.92rem;line-height:1.75;margin-bottom:24px;font-style:italic}
.testimonial-author{display:flex;align-items:center;gap:12px}
.testimonial-author img{width:48px;height:48px;border-radius:50%;object-fit:cover;border:2px solid var(--gold-pale)}
.testimonial-author strong{display:block;font-size:.9rem;font-weight:600}
.testimonial-author span{font-size:.8rem;color:var(--text-muted)}
.slider-controls{display:flex;align-items:center;justify-content:center;gap:16px;margin-top:36px}
.slider-prev,.slider-next{width:44px;height:44px;border-radius:50%;border:2px solid var(--border-light);background:var(--white);color:var(--navy);font-size:.9rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .3s}
.slider-prev:hover,.slider-next:hover{background:var(--gold);color:var(--white);border-color:var(--gold)}
.slider-dots{display:flex;gap:8px}
.slider-dots .dot{width:10px;height:10px;border-radius:50%;background:var(--border-light);cursor:pointer;transition:all .3s}
.slider-dots .dot.active{background:var(--gold);width:28px;border-radius:var(--radius-full)}

/* INDEXING */
.indexing-section{padding:80px 0;background:var(--navy)}
.indexing-section .section-ornament span{color:var(--gold-light)}
.indexing-section .section-title{color:var(--white)}
.indexing-section .section-subtitle{color:rgba(255,255,255,.5)}
.indexing-inner{display:flex;flex-wrap:wrap;justify-content:center;gap:14px}
.index-badge{padding:12px 26px;border-radius:var(--radius-full);font-size:.85rem;font-weight:600;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.05);color:rgba(255,255,255,.8);transition:all .3s;cursor:default}
.index-badge:hover{background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.25);transform:translateY(-2px)}
.index-badge.scopus{border-color:rgba(184,134,11,.5);color:var(--gold-light)}

/* FAQ */
.faq-section{padding:100px 0;background:var(--cream)}
.faq-list{max-width:740px;margin:0 auto}
.faq-item{border:1px solid var(--border-light);border-radius:var(--radius);margin-bottom:12px;overflow:hidden;background:var(--white);transition:all .3s}
.faq-item:hover{border-color:rgba(184,134,11,.3)}
.faq-question{width:100%;display:flex;justify-content:space-between;align-items:center;padding:20px 24px;background:none;border:none;cursor:pointer;font-family:'Inter',sans-serif;font-size:.95rem;font-weight:600;color:var(--navy);text-align:left}
.faq-question:hover{background:rgba(184,134,11,.03)}
.faq-icon{color:var(--gold);transition:transform .3s;flex-shrink:0;margin-left:16px}
.faq-item.open .faq-icon{transform:rotate(45deg)}
.faq-answer{display:none;padding:0 24px 20px;font-size:.9rem;color:var(--text-light);line-height:1.75;border-top:1px solid var(--border-light)}
.faq-item.open .faq-answer{display:block;padding-top:16px}

/* CTA Form Section */
.cta-form-section{padding:120px 0;background:linear-gradient(135deg,rgba(15,25,35,0.88) 0%,rgba(13,27,42,0.92) 40%,rgba(26,35,50,0.9) 100%);position:relative;overflow:hidden}
.cta-form-section::before{content:'';position:absolute;inset:0;background:url('https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=1920&q=80') center/cover no-repeat;z-index:0}
.cta-form-section::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(15,25,35,0.92) 0%,rgba(13,27,42,0.85) 40%,rgba(26,35,50,0.88) 100%);z-index:1}
.cta-particles{position:absolute;inset:0;pointer-events:none;z-index:2}
.cta-particles .particle{position:absolute;width:4px;height:4px;border-radius:50%;background:rgba(184,134,11,0.4);animation:floatParticle var(--dur,8s) ease-in-out infinite;animation-delay:var(--delay,0s)}
@keyframes floatParticle{0%,100%{transform:translate(0,0) scale(1);opacity:.3}25%{transform:translate(var(--tx,30px),var(--ty,-40px)) scale(1.5);opacity:.7}50%{transform:translate(var(--tx2,-20px),var(--ty2,-80px)) scale(1);opacity:.5}75%{transform:translate(var(--tx3,40px),var(--ty3,-30px)) scale(1.3);opacity:.6}}
.cta-form-glow{position:absolute;top:50%;left:30%;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(184,134,11,0.14) 0%,transparent 70%);transform:translate(-50%,-50%);filter:blur(100px);pointer-events:none;z-index:2;animation:ctaGlowPulse 6s ease-in-out infinite}
@keyframes ctaGlowPulse{0%,100%{opacity:.6;transform:translate(-50%,-50%) scale(1)}50%{opacity:1;transform:translate(-50%,-50%) scale(1.15)}}
.cta-form-grid{display:grid;grid-template-columns:1fr 1.2fr;gap:60px;align-items:center;position:relative;z-index:3}
.cta-form-left .section-ornament span{color:var(--gold-light)}
.cta-form-left .section-ornament::before,.cta-form-left .section-ornament::after{background:var(--gold-light);opacity:.3}
.cta-form-left{text-align:left}
.cta-form-left .section-ornament{justify-content:flex-start}
.cta-form-left h2{font-size:2.6rem;color:var(--white);font-weight:800;margin-bottom:20px;line-height:1.15}
.cta-form-left>p{font-size:1.08rem;color:rgba(255,255,255,.6);line-height:1.8;margin-bottom:36px}
.cta-trust-badges{display:flex;flex-direction:column;gap:14px;margin-bottom:32px}
.trust-badge{display:flex;align-items:center;gap:14px;color:rgba(255,255,255,.75);font-size:.92rem;font-weight:500}
.trust-badge i{color:var(--gold-light);font-size:1.1rem;width:40px;height:40px;border-radius:12px;background:rgba(184,134,11,0.12);display:flex;align-items:center;justify-content:center}
.cta-wa-btn{display:inline-flex;align-items:center;gap:10px;background:#25D366;color:var(--white);padding:14px 28px;border-radius:var(--radius-full);font-weight:600;font-size:.92rem;box-shadow:0 6px 20px rgba(37,211,102,0.3);transition:all .3s}
.cta-wa-btn:hover{transform:translateY(-3px);box-shadow:0 10px 30px rgba(37,211,102,0.4)}
.cta-or{color:rgba(255,255,255,.35);font-size:.85rem;margin-top:12px}

/* Glassmorphic Form Card */
.cta-glass-form{background:rgba(255,255,255,0.08);backdrop-filter:blur(32px) saturate(180%);-webkit-backdrop-filter:blur(32px) saturate(180%);border:1px solid rgba(255,255,255,0.15);border-radius:28px;padding:44px 40px;position:relative;overflow:hidden;box-shadow:0 32px 80px rgba(0,0,0,0.3),0 0 0 1px rgba(255,255,255,0.06) inset,0 0 120px rgba(184,134,11,0.06) inset;transition:all .4s}
.cta-glass-form:hover{box-shadow:0 36px 90px rgba(0,0,0,0.35),0 0 0 1px rgba(255,255,255,0.08) inset,0 0 140px rgba(184,134,11,0.08) inset;transform:translateY(-4px)}
.glass-form-shimmer{position:absolute;top:-100%;left:-100%;width:300%;height:300%;background:conic-gradient(from 0deg,transparent 0%,rgba(184,134,11,0.08) 5%,transparent 15%,rgba(255,255,255,0.03) 25%,transparent 35%);animation:formShimmer 12s linear infinite;pointer-events:none}
@keyframes formShimmer{to{transform:rotate(360deg)}}
.cta-glass-form h3{font-family:'Playfair Display',serif;font-size:1.4rem;color:var(--white);margin-bottom:8px;position:relative;z-index:1}
.cta-glass-form h3 i{color:var(--gold-light);margin-right:10px}
.cta-glass-form>p{color:rgba(255,255,255,.5);font-size:.88rem;margin-bottom:28px;position:relative;z-index:1}
.glass-form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.glass-form-group{margin-bottom:16px;position:relative}
.glass-form-group.full{grid-column:1/-1}
.glass-form-group input,.glass-form-group select,.glass-form-group textarea{width:100%;padding:16px 20px;border:1.5px solid rgba(255,255,255,0.12);border-radius:14px;background:rgba(255,255,255,0.05);color:var(--white);font-family:'Inter',sans-serif;font-size:.9rem;outline:none;transition:all .4s;position:relative;z-index:1;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px)}
.glass-form-group input::placeholder,.glass-form-group textarea::placeholder{color:rgba(255,255,255,.4)}
.glass-form-group select{color:rgba(255,255,255,.4)}
.glass-form-group select option{background:var(--navy);color:var(--white)}
.glass-form-group input:focus,.glass-form-group select:focus,.glass-form-group textarea:focus{border-color:var(--gold);background:rgba(255,255,255,0.12);box-shadow:0 0 24px rgba(184,134,11,0.18),0 0 0 3px rgba(184,134,11,0.08)}
.input-glow{position:absolute;bottom:0;left:50%;width:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent);transition:all .4s;transform:translateX(-50%);border-radius:2px}
.glass-form-group input:focus~.input-glow,.glass-form-group select:focus~.input-glow,.glass-form-group textarea:focus~.input-glow{width:80%}
.glass-submit-btn{width:100%;padding:18px;background:linear-gradient(135deg,var(--gold),var(--gold-light),#e6c565);color:var(--white);border:none;border-radius:14px;font-family:'Inter',sans-serif;font-size:1rem;font-weight:700;cursor:pointer;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;gap:10px;transition:all .4s;box-shadow:0 10px 30px rgba(184,134,11,0.35);letter-spacing:.3px}
.glass-submit-btn:hover{transform:translateY(-3px) scale(1.01);box-shadow:0 14px 40px rgba(184,134,11,0.5)}
.glass-submit-btn .btn-icon{display:flex;align-items:center;transition:transform .3s}
.glass-submit-btn:hover .btn-icon{transform:translateX(4px)}
.btn-shimmer{position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.2),transparent);transition:left .6s}
.glass-submit-btn:hover .btn-shimmer{left:100%}
.glass-form-success{display:none;background:rgba(16,185,129,0.12);border:1px solid rgba(16,185,129,0.25);border-radius:12px;padding:16px;text-align:center;color:#6ee7b7;font-weight:600;margin-top:16px;font-size:.9rem;backdrop-filter:blur(8px)}
.glass-form-success i{margin-right:8px;font-size:1.1rem}
.form-privacy{font-size:.75rem;color:rgba(255,255,255,.3);text-align:center;margin-top:16px;position:relative;z-index:1}
.form-privacy i{margin-right:6px;color:rgba(184,134,11,.5)}

/* ======== CALL FOR PAPERS POPUP ======== */
.popup-overlay{position:fixed;inset:0;z-index:10000;background:rgba(15,25,35,0.6);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;padding:20px;opacity:0;transition:opacity .4s ease}
.popup-overlay.show{display:flex;opacity:1}
.popup-container{background:linear-gradient(135deg,#0f1923 0%,#1a2332 50%,#0d1b2a 100%);border-radius:24px;max-width:900px;width:100%;position:relative;overflow:hidden;box-shadow:0 40px 100px rgba(0,0,0,0.4),0 0 0 1px rgba(255,255,255,0.06) inset;animation:popupSlideIn .5s cubic-bezier(.4,0,.2,1) both;max-height:90vh;overflow-y:auto}
@keyframes popupSlideIn{from{opacity:0;transform:translateY(30px) scale(0.95)}to{opacity:1;transform:translateY(0) scale(1)}}
.popup-close{position:absolute;top:16px;right:16px;z-index:10;width:40px;height:40px;border-radius:50%;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.06);backdrop-filter:blur(12px);color:rgba(255,255,255,0.6);font-size:1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .3s}
.popup-close:hover{background:rgba(255,255,255,0.12);color:var(--white);transform:rotate(90deg)}
.popup-particles{position:absolute;inset:0;pointer-events:none;overflow:hidden}
.popup-particles .pp{position:absolute;width:3px;height:3px;border-radius:50%;background:rgba(184,134,11,0.35);animation:ppFloat var(--d,8s) ease-in-out infinite;animation-delay:var(--dl,0s)}
@keyframes ppFloat{0%,100%{transform:translate(0,0);opacity:.2}50%{transform:translate(var(--px,20px),var(--py,-30px));opacity:.6}}
.popup-inner{display:grid;grid-template-columns:1fr 1.1fr;gap:0;position:relative;z-index:2}
.popup-left{padding:44px 36px;display:flex;flex-direction:column;justify-content:center;border-right:1px solid rgba(255,255,255,0.06)}
.popup-badge-wrap{margin-bottom:16px}
.popup-live-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(16,185,129,0.12);color:#6ee7b7;padding:6px 16px;border-radius:var(--radius-full);font-size:.75rem;font-weight:700;letter-spacing:.5px}
.pulse-dot{width:8px;height:8px;border-radius:50%;background:#10b981;animation:pulseDot 2s ease-in-out infinite}
@keyframes pulseDot{0%,100%{box-shadow:0 0 0 0 rgba(16,185,129,0.4)}50%{box-shadow:0 0 0 6px rgba(16,185,129,0)}}
.popup-left h2{font-family:'Playfair Display',serif;font-size:1.8rem;color:var(--white);font-weight:800;margin-bottom:12px;line-height:1.2}
.popup-left h2 i{color:var(--gold-light);margin-right:10px;font-size:1.4rem}
.popup-tagline{font-size:.92rem;color:rgba(255,255,255,0.5);line-height:1.7;margin-bottom:24px}
.popup-features{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:24px}
.popup-feat{display:flex;align-items:center;gap:8px;font-size:.82rem;color:rgba(255,255,255,0.7);font-weight:500}
.popup-feat i{color:var(--gold-light);font-size:.75rem}
.popup-counter{display:flex;gap:20px;padding-top:20px;border-top:1px solid rgba(255,255,255,0.06)}
.popup-counter-item{text-align:center}
.pc-num{display:block;font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:800;color:var(--gold-light);line-height:1}
.pc-lbl{font-size:.7rem;color:rgba(255,255,255,0.35);text-transform:uppercase;letter-spacing:.5px;font-weight:600}

/* Popup Form */
.popup-right{padding:44px 36px}
.popup-form-card{position:relative}
.popup-form-card h3{font-family:'Playfair Display',serif;font-size:1.2rem;color:var(--white);margin-bottom:6px}
.popup-form-card h3 i{color:var(--gold-light);margin-right:8px}
.popup-form-card>p{color:rgba(255,255,255,0.4);font-size:.82rem;margin-bottom:22px}
.popup-form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
.popup-form-card input,.popup-form-card select,.popup-form-card textarea{width:100%;padding:12px 16px;border:1.5px solid rgba(255,255,255,0.08);border-radius:12px;background:rgba(255,255,255,0.05);color:var(--white);font-family:'Inter',sans-serif;font-size:.85rem;outline:none;transition:all .3s}
.popup-form-card input::placeholder,.popup-form-card textarea::placeholder{color:rgba(255,255,255,0.3)}
.popup-form-card select{color:rgba(255,255,255,0.3)}
.popup-form-card select option{background:var(--navy);color:var(--white)}
.popup-form-card input:focus,.popup-form-card select:focus,.popup-form-card textarea:focus{border-color:var(--gold);background:rgba(255,255,255,0.08);box-shadow:0 0 16px rgba(184,134,11,0.1)}
.popup-form-card textarea{margin-bottom:14px;resize:none}
.popup-submit-btn{width:100%;padding:14px;background:linear-gradient(135deg,var(--gold),var(--gold-light));color:var(--white);border:none;border-radius:12px;font-family:'Inter',sans-serif;font-size:.95rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:all .4s;box-shadow:0 8px 24px rgba(184,134,11,0.3);position:relative;overflow:hidden}
.popup-submit-btn:hover{transform:translateY(-2px);box-shadow:0 12px 35px rgba(184,134,11,0.45)}
.popup-submit-btn::after{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.15),transparent);transition:left .5s}
.popup-submit-btn:hover::after{left:100%}
.popup-form-success{display:none;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.2);border-radius:12px;padding:14px;text-align:center;color:#6ee7b7;font-weight:600;margin-top:14px;font-size:.85rem}
.popup-privacy{font-size:.72rem;color:rgba(255,255,255,0.25);text-align:center;margin-top:14px}
.popup-privacy i{margin-right:5px;color:rgba(184,134,11,0.4)}

/* Popup Responsive */
@media(max-width:768px){
.popup-inner{grid-template-columns:1fr}
.popup-left{border-right:none;border-bottom:1px solid rgba(255,255,255,0.06);padding:32px 24px}
.popup-right{padding:28px 24px}
.popup-features{grid-template-columns:1fr}
.popup-form-row{grid-template-columns:1fr}
.popup-left h2{font-size:1.5rem}
.popup-container{max-height:85vh}
}

/* FOOTER */
footer{background:var(--navy-deep);color:rgba(255,255,255,.6);padding:72px 0 0}
.footer-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr 1.2fr;gap:48px;padding-bottom:56px}
.footer-logo{display:flex;align-items:center;gap:10px;margin-bottom:16px}
.footer-logo-img{height:44px;filter:brightness(10)}
.footer-desc{color:rgba(255,255,255,.45);font-size:.9rem;margin-bottom:20px;line-height:1.7}
.social-links{display:flex;gap:10px}
.social-links a{width:38px;height:38px;border-radius:50%;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.04);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.5);font-size:.85rem;transition:all .3s}
.social-links a:hover{background:var(--gold);border-color:var(--gold);color:var(--white)}
.footer-col h4{color:var(--white);font-family:'Inter',sans-serif;font-size:.82rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:20px;padding-bottom:12px;position:relative}
.footer-col h4::after{content:'';position:absolute;left:0;bottom:0;width:28px;height:2px;background:var(--gold)}
.footer-col ul li{margin-bottom:10px}
.footer-col ul li a{color:rgba(255,255,255,.45);font-size:.88rem}
.footer-col ul li a:hover{color:var(--gold-light);padding-left:4px}
footer p{font-size:.88rem;margin-bottom:8px;color:rgba(255,255,255,.45)}
footer p i{color:var(--gold-light);margin-right:8px;width:16px}
.footer-bottom{border-top:1px solid rgba(255,255,255,.06);padding:20px 0;text-align:center}
.footer-bottom p{font-size:.82rem;color:rgba(255,255,255,.3);margin:0}

/* PAGE HERO (subpages) */
.page-hero{padding:140px 20px 70px;text-align:center;background:linear-gradient(135deg,var(--cream) 0%,var(--cream-dark) 50%,rgba(184,134,11,0.05) 100%);position:relative}
.page-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 80%,rgba(184,134,11,0.06) 0%,transparent 60%)}
.page-hero-inner{position:relative;z-index:1}
.page-hero .breadcrumb{font-size:.85rem;color:var(--text-muted);margin-bottom:12px}
.page-hero .breadcrumb a{color:var(--gold)}
.page-hero-eyebrow{display:inline-flex;align-items:center;gap:8px;color:var(--gold);font-size:.72rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;margin-bottom:12px}
.page-hero h1{font-size:clamp(2rem,5vw,3.2rem);font-weight:800;margin-bottom:16px}
.page-hero h1 em{color:var(--gold);font-style:italic}
.page-hero p{font-size:1.05rem;color:var(--text-light);max-width:560px;margin:0 auto;line-height:1.75}

/* WHATSAPP FLOAT */
.whatsapp-float{position:fixed;bottom:24px;right:24px;z-index:998;background:#25D366;color:white;width:54px;height:54px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.5rem;box-shadow:0 6px 20px rgba(37,211,102,.4);transition:all .3s}
.whatsapp-float:hover{transform:scale(1.1);box-shadow:0 8px 28px rgba(37,211,102,.5)}

/* CONTACT */
.contact-section{padding:80px 0;background:var(--white)}
.contact-grid{display:grid;grid-template-columns:1fr 1.5fr;gap:56px;align-items:start}
.contact-info h2{font-size:1.8rem;margin-bottom:16px;font-weight:800}
.contact-info h2 em{color:var(--gold);font-style:italic}
.contact-info>p{color:var(--text-light);margin-bottom:36px}
.contact-detail{display:flex;align-items:flex-start;gap:16px;margin-bottom:24px}
.cd-icon{width:48px;height:48px;border-radius:var(--radius);background:rgba(184,134,11,0.08);display:flex;align-items:center;justify-content:center;color:var(--gold);font-size:1.1rem;flex-shrink:0}
.cd-text h4{font-size:.88rem;margin-bottom:2px;font-weight:700}
.cd-text p,.cd-text a{font-size:.9rem;color:var(--text-light)}
.cd-text a:hover{color:var(--gold)}
.contact-social{margin-top:32px}
.contact-social h4{font-family:'Inter',sans-serif;font-size:.82rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:14px}
.social-row{display:flex;gap:10px}
.social-row a{width:40px;height:40px;border-radius:50%;background:var(--cream);border:1px solid var(--border-light);display:flex;align-items:center;justify-content:center;color:var(--text-light);font-size:.85rem;transition:all .3s}
.social-row a:hover{background:var(--gold);color:white;border-color:var(--gold)}

/* FORM */
.contact-form-wrap{background:var(--glass);backdrop-filter:blur(12px);border:1px solid var(--glass-border);border-radius:var(--radius-lg);padding:44px;box-shadow:var(--shadow)}
.contact-form-wrap h2{font-size:1.5rem;margin-bottom:6px;font-weight:800}
.contact-form-wrap>p{color:var(--text-light);font-size:.9rem;margin-bottom:28px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.form-group{margin-bottom:20px}
.form-group label{display:block;font-size:.78rem;font-weight:700;color:var(--navy);margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px}
.form-group input,.form-group select,.form-group textarea{width:100%;padding:14px 18px;border:1.5px solid var(--border-light);border-radius:var(--radius);font-family:'Inter',sans-serif;font-size:.9rem;color:var(--text);background:var(--white);outline:none;transition:all .3s}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(184,134,11,0.08)}
.form-group textarea{resize:vertical;min-height:90px}
.checkbox-group{display:flex;flex-wrap:wrap;gap:10px;margin-top:6px}
.checkbox-group label{display:inline-flex;align-items:center;gap:6px;font-size:.85rem;font-weight:500;color:var(--text-light);cursor:pointer;padding:8px 16px;border:1.5px solid var(--border-light);border-radius:var(--radius-full);transition:all .3s;background:var(--white);text-transform:none;letter-spacing:0}
.checkbox-group label:hover{border-color:var(--gold)}
.checkbox-group input[type="checkbox"]{accent-color:var(--gold);width:16px;height:16px}
.checkbox-group label:has(input:checked){background:rgba(184,134,11,0.06);border-color:var(--gold);color:var(--gold)}
.word-count{font-size:.75rem;color:var(--text-muted);margin-top:6px;text-align:right}
.btn-submit{width:100%;padding:16px;background:var(--gold);color:white;border:none;border-radius:var(--radius);font-family:'Inter',sans-serif;font-size:1rem;font-weight:600;cursor:pointer;transition:all .3s;box-shadow:var(--shadow-gold)}
.btn-submit:hover{background:var(--gold-light);transform:translateY(-2px)}
.form-success{display:none;background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.2);border-radius:var(--radius);padding:16px;text-align:center;color:#065f46;font-weight:600;margin-top:16px}

/* SERVICES DETAIL (Services page) */
.services-detail{padding:80px 0;background:var(--white)}
.service-item{display:grid;grid-template-columns:72px 1fr;gap:24px;background:var(--cream);border:1px solid var(--border-light);border-radius:var(--radius);padding:32px;margin-bottom:18px;transition:all .4s}
.service-item:hover{border-color:rgba(184,134,11,0.3);box-shadow:var(--shadow);transform:translateX(4px)}
.service-item-icon{width:64px;height:64px;border-radius:var(--radius);background:rgba(184,134,11,0.08);display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:var(--gold);flex-shrink:0}
.service-item-icon.alt{background:var(--cream-dark);color:var(--navy)}
.service-item-body h3{font-size:1.15rem;margin-bottom:10px}
.service-item-body p{color:var(--text-light);font-size:.9rem;margin-bottom:14px;line-height:1.7}
.service-features{display:flex;flex-wrap:wrap;gap:8px}
.feature-tag{background:rgba(184,134,11,0.06);color:var(--gold);padding:4px 14px;border-radius:var(--radius-full);font-size:.75rem;font-weight:600;border:1px solid rgba(184,134,11,0.12)}

/* PROCESS (Services page) */
.process-inner{display:grid;grid-template-columns:1fr 380px;gap:56px;align-items:start}
.steps-list{max-width:100%}
.process-img-wrap{position:sticky;top:96px}
.process-img{width:100%;border-radius:var(--radius);border:1px solid var(--border-light);object-fit:cover;box-shadow:var(--shadow-lg)}
.step-row{display:flex;gap:24px;margin-bottom:22px;align-items:flex-start;padding-bottom:22px;border-bottom:1px solid var(--border-light)}
.step-row:last-child{border-bottom:none;padding-bottom:0;margin-bottom:0}
.step-num{width:48px;height:48px;border-radius:var(--radius);background:var(--gold);color:white;font-family:'Playfair Display',serif;font-size:.9rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.step-content h3{font-size:1.05rem;margin-bottom:6px}
.step-content p{color:var(--text-light);font-size:.88rem;line-height:1.7}

/* PRICING */
.pricing-section{padding:80px 0;background:var(--cream)}
.pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.pricing-card{background:var(--white);border:1px solid var(--border-light);border-radius:var(--radius-lg);padding:40px 28px;text-align:center;transition:all .4s;position:relative}
.pricing-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-lg)}
.pricing-card.featured{border-color:var(--gold);box-shadow:0 0 30px rgba(184,134,11,0.12)}
.featured-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--gold);color:white;padding:4px 18px;border-radius:var(--radius-full);font-size:.72rem;font-weight:700;letter-spacing:1px;text-transform:uppercase}
.pricing-card h3{font-size:1.2rem;margin-bottom:10px}
.pricing-card .price{font-size:.92rem;color:var(--text-light);margin-bottom:24px}
.pricing-list{text-align:left;margin-bottom:28px}
.pricing-list li{padding:9px 0;font-size:.85rem;border-bottom:1px solid var(--border-light);display:flex;align-items:center;gap:10px}
.pricing-list li i{color:var(--gold);font-size:.8rem;flex-shrink:0}

/* ABOUT */
.mission-section{padding:80px 0;background:var(--white)}
.mission-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center}
.mission-text h2{font-size:2rem;margin-bottom:20px;font-weight:800}
.mission-text p{color:var(--text-light);margin-bottom:16px;line-height:1.75}
.mission-text .highlight{color:var(--gold);font-weight:700}
.mission-image{border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-lg)}
.mission-image img{width:100%;height:400px;object-fit:cover}
.stats-bar{background:linear-gradient(135deg,var(--navy-deep),var(--navy));padding:56px 0}
.stats-bar-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;text-align:center}
.stat-item .num{font-family:'Playfair Display',serif;font-size:2.8rem;color:var(--gold-light);font-weight:800;line-height:1;margin-bottom:8px}
.stat-item .lbl{font-size:.85rem;color:rgba(255,255,255,.5);font-weight:500}
.values-section{padding:80px 0;background:var(--cream)}
.values-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
.value-card{background:var(--white);border:1px solid var(--border-light);border-radius:var(--radius-lg);padding:36px 24px;text-align:center;transition:all .4s}
.value-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-lg);border-color:rgba(184,134,11,0.3)}
.value-icon{font-size:2rem;color:var(--gold);margin-bottom:16px}
.value-card h3{font-size:1.05rem;margin-bottom:10px}
.value-card p{font-size:.88rem;color:var(--text-light);line-height:1.65}
.why-section{padding:80px 0;background:var(--white)}
.why-list{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.why-item{background:var(--cream);border:1px solid var(--border-light);border-radius:var(--radius);padding:28px;display:flex;gap:18px;align-items:flex-start;transition:all .3s}
.why-item:hover{border-color:rgba(184,134,11,0.3);box-shadow:var(--shadow);transform:translateY(-2px)}
.why-icon{font-size:1.3rem;color:var(--gold);flex-shrink:0;width:48px;height:48px;background:rgba(184,134,11,0.08);border-radius:var(--radius);display:flex;align-items:center;justify-content:center}
.why-text h4{font-size:.95rem;margin-bottom:6px;font-weight:700}
.why-text p{font-size:.85rem;color:var(--text-light);line-height:1.65}
.faq-strip{padding:80px 0;background:var(--cream)}
.faq-strip h2{font-size:2rem;text-align:center;margin-bottom:12px}
.faq-strip>.container>p{text-align:center;color:var(--text-light);margin-bottom:40px}

/* AI CHATBOT */
.chatbot-toggle{position:fixed;bottom:24px;right:90px;z-index:999;width:54px;height:54px;border-radius:50%;background:var(--navy);color:var(--white);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1.3rem;box-shadow:0 6px 25px rgba(26,35,50,0.4);transition:all .3s}
.chatbot-toggle:hover{transform:scale(1.08);box-shadow:0 8px 30px rgba(26,35,50,0.5)}
.chatbot-toggle .badge{position:absolute;top:-2px;right:-2px;width:18px;height:18px;background:var(--gold);border-radius:50%;font-size:.65rem;font-weight:700;display:flex;align-items:center;justify-content:center}
.chatbot-window{position:fixed;bottom:90px;right:90px;z-index:1001;width:380px;max-height:520px;background:var(--white);border-radius:var(--radius-lg);box-shadow:0 25px 80px rgba(0,0,0,0.2);display:none;flex-direction:column;overflow:hidden;border:1px solid var(--border-light);animation:chatSlideUp .3s ease}
.chatbot-window.open{display:flex}
@keyframes chatSlideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.chat-header{background:var(--navy);color:var(--white);padding:18px 20px;display:flex;align-items:center;gap:12px}
.chat-avatar{width:40px;height:40px;border-radius:50%;background:var(--gold);display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}
.chat-header-info h4{font-family:'Inter',sans-serif;font-size:.95rem;font-weight:600;margin-bottom:2px}
.chat-header-info span{font-size:.75rem;color:rgba(255,255,255,.6);display:flex;align-items:center;gap:4px}
.chat-header-info span::before{content:'';width:6px;height:6px;border-radius:50%;background:#10b981}
.chat-close{margin-left:auto;background:none;border:none;color:rgba(255,255,255,.6);cursor:pointer;font-size:1.1rem;padding:4px}
.chat-close:hover{color:var(--white)}
.chat-body{flex:1;overflow-y:auto;padding:20px;max-height:340px}
.chat-topics{margin-bottom:16px}
.chat-topics h5{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text-muted);margin-bottom:10px}
.chat-chips{display:flex;flex-wrap:wrap;gap:6px}
.chat-chip{background:var(--cream);border:1px solid var(--border-light);border-radius:var(--radius-full);padding:6px 14px;font-size:.8rem;font-weight:500;cursor:pointer;transition:all .2s;color:var(--text)}
.chat-chip:hover{background:rgba(184,134,11,0.08);border-color:var(--gold);color:var(--gold)}
.chat-message{margin-bottom:14px;display:flex;gap:8px;align-items:flex-start}
.chat-message.bot .msg-avatar{width:28px;height:28px;border-radius:50%;background:var(--navy);color:var(--white);display:flex;align-items:center;justify-content:center;font-size:.7rem;flex-shrink:0}
.chat-message .msg-bubble{background:var(--cream);border-radius:var(--radius) var(--radius) var(--radius) 4px;padding:12px 16px;font-size:.88rem;line-height:1.6;color:var(--text);max-width:85%}
.chat-message.user{justify-content:flex-end}
.chat-message.user .msg-bubble{background:var(--navy);color:var(--white);border-radius:var(--radius) var(--radius) 4px var(--radius)}
.chat-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:12px}
.chat-grid-item{background:var(--cream);border:1px solid var(--border-light);border-radius:var(--radius);padding:14px;text-align:center;cursor:pointer;transition:all .2s}
.chat-grid-item:hover{border-color:var(--gold);background:rgba(184,134,11,0.05)}
.chat-grid-item .grid-icon{font-size:1.3rem;margin-bottom:6px}
.chat-grid-item .grid-label{font-size:.78rem;font-weight:600;color:var(--text)}
.chat-timestamp{font-size:.7rem;color:var(--text-muted);margin-top:4px;text-align:center}
.chat-footer-actions{padding:12px 16px;border-top:1px solid var(--border-light);display:flex;flex-direction:column;gap:8px}
.chat-cta-btn{display:flex;align-items:center;justify-content:center;gap:8px;padding:12px 16px;background:linear-gradient(135deg,var(--gold),var(--gold-light));color:var(--white);border-radius:var(--radius-full);font-size:.88rem;font-weight:700;text-align:center;transition:all .3s;box-shadow:0 4px 16px rgba(184,134,11,0.3);cursor:pointer}
.chat-cta-btn:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(184,134,11,0.4)}
.chat-wa-btn{display:flex;align-items:center;justify-content:center;gap:8px;padding:10px 16px;background:#25D366;color:var(--white);border-radius:var(--radius-full);font-size:.85rem;font-weight:600;text-align:center;transition:all .3s;box-shadow:0 4px 12px rgba(37,211,102,0.25)}
.chat-wa-btn:hover{transform:translateY(-2px);box-shadow:0 6px 18px rgba(37,211,102,0.35)}
.chat-inline-cta{display:inline-flex;align-items:center;gap:6px;padding:8px 18px;background:linear-gradient(135deg,var(--gold),var(--gold-light));color:var(--white)!important;border-radius:var(--radius-full);font-size:.82rem;font-weight:700;margin-top:4px;transition:all .3s;box-shadow:0 4px 12px rgba(184,134,11,0.25)}
.chat-inline-cta:hover{transform:translateY(-1px);box-shadow:0 6px 18px rgba(184,134,11,0.35)}
.chat-powered{font-size:.68rem;color:var(--text-muted);text-align:center;padding:6px;border-top:1px solid var(--border-light)}
.chat-powered a{color:var(--gold);font-weight:600}

/* Glassmorphic Service Cards Enhancement */
.service-card{background:rgba(255,255,255,0.7);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.5);transition:all .5s cubic-bezier(.4,0,.2,1)}
.service-card:hover{background:rgba(255,255,255,0.9);box-shadow:0 20px 60px rgba(0,0,0,0.1),0 0 40px rgba(184,134,11,0.08);transform:translateY(-10px)}
.service-card::after{content:'';position:absolute;inset:0;border-radius:var(--radius-lg);background:linear-gradient(135deg,rgba(184,134,11,0.03),transparent);opacity:0;transition:opacity .4s}
.service-card:hover::after{opacity:1}

/* Enhanced Value Items */
.v-item{background:rgba(255,255,255,0.6);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.4);transition:all .4s cubic-bezier(.4,0,.2,1)}
.v-item:hover{background:rgba(255,255,255,0.9);box-shadow:0 16px 48px rgba(0,0,0,0.08)}

/* Enhanced Index Badges */
.index-badge{backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);transition:all .4s cubic-bezier(.4,0,.2,1)}
.index-badge:hover{background:rgba(255,255,255,.12);box-shadow:0 0 24px rgba(184,134,11,0.15);transform:translateY(-4px) scale(1.05)}
.index-badge.scopus{animation:scopusPulse 3s ease-in-out infinite}
@keyframes scopusPulse{0%,100%{box-shadow:0 0 0 0 rgba(184,134,11,0.2)}50%{box-shadow:0 0 20px 4px rgba(184,134,11,0.15)}}

/* Glassmorphic FAQ */
.faq-item{background:rgba(255,255,255,0.7);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.4)}
.faq-item:hover{background:rgba(255,255,255,0.9)}
.faq-item.open{box-shadow:0 12px 36px rgba(0,0,0,0.06)}

/* Enhanced Step Circles */
.step-circle{position:relative;overflow:hidden}
.step-circle::after{content:'';position:absolute;inset:0;border-radius:50%;background:linear-gradient(135deg,transparent 40%,rgba(255,255,255,0.3) 50%,transparent 60%);animation:stepShine 4s ease-in-out infinite}
@keyframes stepShine{0%,100%{transform:translateX(-100%)}50%{transform:translateX(100%)}}

/* Enhanced Testimonial Cards */
.testimonial-card{background:rgba(255,255,255,0.7);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.4);transition:all .4s cubic-bezier(.4,0,.2,1)}
.testimonial-card:hover{background:rgba(255,255,255,0.95);box-shadow:0 20px 50px rgba(0,0,0,0.08)}

/* Floating Orbs (added by JS) */
.floating-orb{position:fixed;border-radius:50%;pointer-events:none;z-index:0;filter:blur(60px);opacity:.12;animation:orbFloat var(--orb-dur,20s) ease-in-out infinite}
@keyframes orbFloat{0%,100%{transform:translate(0,0)}33%{transform:translate(var(--orb-x,30px),var(--orb-y,-40px))}66%{transform:translate(var(--orb-x2,-20px),var(--orb-y2,30px))}}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
.reveal{opacity:0;transform:translateY(24px);transition:opacity .7s cubic-bezier(.4,0,.2,1),transform .7s cubic-bezier(.4,0,.2,1)}
.reveal.visible{opacity:1;transform:none}
.hero-eyebrow{animation:fadeUp .6s ease both .1s}
.hero h1{animation:fadeUp .6s ease both .25s}
.hero-sub{animation:fadeUp .6s ease both .4s}
.hero-actions{animation:fadeUp .6s ease both .55s}
.hero-stats{animation:fadeUp .6s ease both .7s}
.hero-carousel{animation:fadeUp .8s ease both .5s}
.page-hero-eyebrow{animation:fadeUp .5s ease both}
.page-hero h1{animation:fadeUp .5s ease both .15s}
.page-hero p{animation:fadeUp .5s ease both .3s}

/* RESPONSIVE */
@media(max-width:1024px){
.hero{grid-template-columns:1fr;text-align:center;padding-top:120px}
.hero-content{max-width:100%}.hero-sub{margin:0 auto 36px}
.hero-actions{justify-content:center}.hero-stats{justify-content:center}
.hero-carousel{max-width:100%;margin:40px auto 0}
.carousel-viewport{height:340px}
.carousel-slide{width:280px}
.value-inner{grid-template-columns:1fr;gap:48px}
.cmp-grid{grid-template-columns:1fr}
.process-inner{grid-template-columns:1fr}.process-img-wrap{display:none}
.values-grid{grid-template-columns:repeat(2,1fr)}
.cta-form-grid{grid-template-columns:1fr;gap:40px}
.cta-form-left{text-align:center}
.cta-form-left .section-ornament{justify-content:center}
.cta-trust-badges{align-items:center}
.cta-contact-quick{display:flex;flex-direction:column;align-items:center}
}
@media(max-width:768px){
nav{display:none;position:fixed;top:72px;left:0;right:0;background:rgba(255,255,255,.98);backdrop-filter:blur(20px);padding:20px;border-top:1px solid var(--border-light);box-shadow:var(--shadow-lg)}
nav.open{display:block}
nav ul{flex-direction:column;gap:4px}
nav ul li a{display:block;padding:12px 16px}
.mobile-menu-btn{display:block}
.stats-grid{grid-template-columns:repeat(2,1fr)}
.services-grid{grid-template-columns:1fr}
.process-steps{grid-template-columns:1fr 1fr}
.testimonial-card{min-width:100%}
.footer-grid{grid-template-columns:1fr 1fr;gap:32px}
.contact-grid{grid-template-columns:1fr}
.form-row{grid-template-columns:1fr}
.mission-grid{grid-template-columns:1fr}.mission-image{order:-1}
.stats-bar-grid{grid-template-columns:repeat(2,1fr);gap:24px}
.why-list{grid-template-columns:1fr}
.pricing-grid{grid-template-columns:1fr}
.service-item{grid-template-columns:1fr}
.page-hero{padding:120px 20px 60px}
.chatbot-window{right:10px;left:10px;width:auto;bottom:80px}
.carousel-refund-badge{width:60px;height:60px;font-size:.55rem;top:0;right:0}.carousel-refund-badge .big{font-size:1rem}
.cta-form-grid{grid-template-columns:1fr}
.cta-form-left{text-align:center}
.cta-form-left .section-ornament{justify-content:center}
.cta-trust-badges{align-items:center}
.cta-contact-quick{display:flex;flex-direction:column;align-items:center}
.cta-or{display:none}
.glass-form-row{grid-template-columns:1fr}
}
@media(max-width:480px){
.hero h1{font-size:2rem}
.hero-actions{flex-direction:column;align-items:center}
.hero-stats{flex-direction:column;align-items:center;gap:20px}
.stats-grid{grid-template-columns:1fr 1fr;gap:12px}
.footer-grid{grid-template-columns:1fr}
.process-steps{grid-template-columns:1fr}
.contact-form-wrap{padding:28px 18px}
.stats-bar-grid{grid-template-columns:1fr 1fr}
.logo-name{display:none}
.values-grid{grid-template-columns:1fr}
.cta-glass-form{padding:24px 18px}
.cta-form-left h2{font-size:2rem}
.carousel-viewport{height:300px}
.carousel-slide{width:240px}
.c-card{padding:24px 20px}
.c-icon{width:44px;height:44px;font-size:1rem}
.c-card h3{font-size:1.05rem}
}
